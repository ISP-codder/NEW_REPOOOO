{
	"name": "generdoc5",
	"version": "1.0.0",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder"
	},
	"keywords": [],
	"author": "Angelina",
	"license": "ISC",
	"description": "Приложение для ЮК ШИП",
	"devDependencies": {
		"electron": "^41.0.3",
		"electron-builder": "^24.13.3"
	},
	"dependencies": {
		"docx": "^9.6.1",
		"image-size": "^2.0.2",
		"sharp": "^0.34.5"
	},
	"build": {
		"appId": "com.angelina.yukship",
		"productName": "ЮК ШИП",
		"directories": {
			"output": "dist"
		},
		"win": {
			"target": "nsis",
			"icon": "src/assets/images/clipboard.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"installerIcon": "src/assets/images/clipboard.ico",
			"uninstallerIcon": "src/assets/images/clipboard.ico",
			"createDesktopShortcut": true
		}
	}
}
